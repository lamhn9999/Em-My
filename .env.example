# ─────────────────────────────────────────────
#  Zalo Booking Agent — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── ZALO: OA ACCESS TOKEN ────────────────────
ZALOOA_ID=
ZALOOA_ACCESS_TOKEN=
# ── LLM: Groq (free tier) ────────────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=gsk...

# Groq model (default is the best free option)
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM: Ollama (local, fully free/offline) ──
# Requires: brew install ollama && ollama pull llama3.2
# Set to "true" to bypass Groq and use local Ollama
USE_OLLAMA=false
OLLAMA_MODEL=llama3.2

# ── Google Calendar ───────────────────────────
# Leave as "primary" to use your main calendar
# Or paste a specific calendar ID from Google Calendar settings
GOOGLE_CALENDAR_ID=primary
